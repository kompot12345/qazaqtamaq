# Backend Environment Configuration
# Copy this to .env and fill in your values

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/qazaqtamaq_db

# JWT Configuration
JWT_SECRET=your-super-secret-key-with-minimum-32-characters-here
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=3001

# CORS Configuration (Frontend URL)
CORS_ORIGIN=http://localhost:3000,https://yourdomain.vercel.app

# Environment
NODE_ENV=development
